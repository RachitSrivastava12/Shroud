# ─── network ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SHROUD_NETWORK=devnet

# Solana RPC. A Helius devnet endpoint is strongly recommended.
NEXT_PUBLIC_DEVNET_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_MAINNET_RPC=https://api.mainnet-beta.solana.com

# ─── scheduler ───────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
# Must be >= 32 chars. Only the server uses it. NEVER commit.
SCHEDULER_SECRET=change-me-to-a-long-random-string-of-at-least-32-bytes

# Protects /api/cron from public callers. Vercel cron sends this as
# Authorization: Bearer <CRON_SECRET>
CRON_SECRET=another-long-random-string

# ─── storage ─────────────────────────────────────────────────────────
# Optional — without these, Shroud falls back to a local JSON file for
# dev. Required for Vercel deploy.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
